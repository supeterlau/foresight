# Backend environment variables for Foresight EM Agent

# CORS allowed origins (comma-separated). In production, set to your frontend URL.
CORS_ORIGINS=http://localhost:5173

# GitLab OAuth application credentials (required for OAuth flow)
# Create at: https://gitlab.com/-/user_settings/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# GitLab personal access token (required for API/MCP mode without OAuth)
# Create at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_PRIVATE_TOKEN=

# GitLab instance URL (optional, defaults to https://gitlab.com)
GITLAB_URL=https://gitlab.com

# Server port
PORT=8080
